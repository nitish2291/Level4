---
import BaseLayout from "../layouts/BaseLayout.astro";
import menu from "../content/menu.json";
---

<BaseLayout>

<section class="menu-page">

<h1>Our Menu</h1>

<div class="menu-nav">

<label class="veg-switch-inline">

<input type="checkbox" id="vegMode">

<span class="veg-slider"></span>

<span class="veg-text">Veg Mode 🌿</span>

</label>
{menu.categories.map(category => (

<a href={`#${category.name.replace(/\s+/g,'-').toLowerCase()}`}>
{category.name}
</a>

))}

</div>

{menu.categories.map(category => (

<div
class="menu-category"
id={category.name.replace(/\s+/g,'-').toLowerCase()}
>

<h2>{category.name}</h2>

<div class="menu-grid">

{category.items.map(item => (

<div class={`menu-card ${item.type}`}>

<img
src={item.image}
alt={item.name}
loading="lazy"
/>

<div class="menu-info">

<h3>
{item.name}
<span class="food-icon">
{
item.type === "veg" ? "🌱" :
item.type === "nonveg" ? "🍗" :
item.type === "egg" ? "🥚" :
item.type === "drinks" ? "🍹" :
item.type === "dessert" ? "🍰" : ""
}
</span>
</h3>

<span class="price">₹{item.price}</span>

</div>

</div>

))}

</div>  <!-- menu-grid -->

</div>  <!-- menu-category -->

))}

</section>

</BaseLayout>

<script src="/src/scripts/menu-scroll.js"></script>

<script src="/src/scripts/menu-scroll.js"></script>

<script>

const vegToggle = document.getElementById("vegMode");

vegToggle.addEventListener("change", () => {

document.body.classList.toggle("veg-active");

const nonVegItems = document.querySelectorAll(".nonveg, .egg");

nonVegItems.forEach(item => {
item.style.display = vegToggle.checked ? "none" : "block";
});

});

</script>