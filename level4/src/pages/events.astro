---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Events | Level 4">

<!-- HERO -->

<section class="events-hero">

<div class="hero-content">

<h1>Host Your Celebration at Level 4</h1>

<p>
Birthday parties, anniversaries, corporate gatherings and private rooftop events.
</p>

<a href="https://wa.me/917033566638" class="btn-primary">
Plan Your Event
</a>

</div>

</section>


<!-- EVENT TYPES -->

<section class="event-types container">

<h2>Events We Host</h2>

<div class="event-grid">

<div class="event-card">
<img src="/images/birthday.jpg" alt="Birthday Party"/>
<h3>Birthday Parties</h3>
<p>Celebrate your special day with rooftop views, music and great food.</p>
</div>

<div class="event-card">
<img src="/images/corporate.jpg" alt="Corporate Event"/>
<h3>Corporate Gatherings</h3>
<p>Perfect venue for office parties, team dinners and client meetings.</p>
</div>

<div class="event-card">
<img src="/images/anniversary.jpg" alt="Anniversary"/>
<h3>Anniversary Celebrations</h3>
<p>Romantic rooftop dinners with candlelight arrangements.</p>
</div>

<div class="event-card">
<img src="/images/private.jpg" alt="Private Party"/>
<h3>Private Parties</h3>
<p>Reserve the rooftop space for exclusive celebrations.</p>
</div>

</div>

</section>


<!-- PACKAGES -->

<section class="packages">

<h2>Event Packages</h2>

<div class="package-grid">

<div class="package">
<h3>Basic Celebration</h3>
<p>Reserved tables and standard setup</p>
<span>₹999 / person</span>
</div>

<div class="package">
<h3>Premium Celebration</h3>
<p>Decor, music and event arrangements</p>
<span>₹1299 / person</span>
</div>

<div class="package">
<h3>Private Rooftop</h3>
<p>Entire rooftop reserved for your event</p>
<span>Custom Quote</span>
</div>

</div>

</section>


<!-- GALLERY -->

<section class="gallery-section">

<h2>Real Celebrations at Level 4</h2>

<p>Take a look at the memories created on our rooftop.</p>

<div class="instagram-wrapper">

<script src="https://cdn.lightwidget.com/widgets/lightwidget.js"></script>

<iframe
src="//lightwidget.com/widgets/a114ab57458e586090b7e484802db369.html"
scrolling="no"
allowtransparency="true"
class="lightwidget-widget">
</iframe>

</div>

<div class="instagram-follow">
  <a href="https://instagram.com/level4rooftop" target="_blank" rel="noopener" class="insta-follow-btn">
    <img src="/images/instagram-icon.svg" alt="Instagram" class="insta-icon">
    Follow on Instagram
  </a>
</div>

</section>


<!-- VENUE DETAILS -->

<section class="venue">

<h2>Venue Details</h2>

<ul>

<li>🌆 Rooftop open seating</li>

<li>👥 Capacity: 40–60 guests</li>

<li>🎉 Custom decor available</li>

<li>🎵 Music system available</li>

<li>🍜 Multi-cuisine food</li>

</ul>

</section>


<!-- BOOKING -->

<section class="event-booking">

<h2>Plan Your Event With Us</h2>

<p>
Tell us your guest count and date. We'll help you organise the perfect rooftop celebration.
</p>

<div class="booking-actions">

<a href="tel:+917033566638" class="btn-secondary">
Call Us
</a>

<a href="https://wa.me/917033566638" class="btn-primary">
Chat on WhatsApp
</a>

</div>

</section>


<style>

/* HERO */

.events-hero{

padding:180px 20px;

background:
linear-gradient(rgba(0,0,0,.65),rgba(0,0,0,.75)),
url("/images/celebrations-3.jpg");

background-size:cover;
background-position:center;

background-attachment:fixed;

text-align:center;

}

.events-hero h1{
font-size:48px;
margin-bottom:15px;
}

.events-hero p{
max-width:600px;
margin:0 auto 30px auto;
opacity:.9;
}


/* EVENT TYPES */

.event-grid{

display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));

gap:30px;

margin-top:40px;

}

.event-card{

background:#141414;

border-radius:10px;

overflow:hidden;

transition:transform .25s ease, box-shadow .25s ease;

}

.event-card:hover{

transform:translateY(-6px);

box-shadow:0 10px 28px rgba(0,0,0,.45);

}

.event-card img{

width:100%;

height:200px;

object-fit:cover;

}

.event-card h3{
margin:12px 15px 5px 15px;
}

.event-card p{
margin:0 15px 20px 15px;
opacity:.8;
}


/* PACKAGES */

.packages{
padding:90px 20px;
text-align:center;
}

.package-grid{

display:grid;

grid-template-columns:repeat(auto-fit,minmax(250px,1fr));

gap:30px;

margin-top:40px;

}

.package{

background:#141414;

border-radius:10px;

padding:35px;

border:1px solid rgba(255,255,255,.08);

transition:transform .25s ease, box-shadow .25s ease;

position:relative;

overflow:hidden;

}

.package::before{

content:"";

position:absolute;

top:0;
left:0;
right:0;

height:4px;

background:linear-gradient(
90deg,
#FFD700,
#FF6B6B,
#6BCB77,
#4D96FF
);

}

.package:hover{

transform:translateY(-6px);

box-shadow:0 12px 30px rgba(0,0,0,.45);

}

.package span{

display:block;

margin-top:15px;

font-weight:600;

color:#FFD700;

}


/* GALLERY */

.gallery-section{

text-align:center;

padding:90px 20px;

}

.instagram-wrapper{

max-width:850px;

margin:40px auto;

}


/* VENUE */

.venue{

padding:90px 20px;

text-align:center;

}

.venue ul{

list-style:none;

padding:0;

max-width:500px;

margin:30px auto;

}

.venue li{

margin:12px 0;

opacity:.9;

}


/* BOOKING */

.event-booking{

padding:120px 20px;

text-align:center;

}

.booking-actions{

margin-top:30px;

display:flex;

gap:15px;

justify-content:center;

flex-wrap:wrap;

}

</style>

</BaseLayout>