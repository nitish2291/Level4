---
import BaseLayout from "../layouts/BaseLayout.astro";
import menu from "../content/menu.json";
import gallery from "../content/gallery.json";
---

<BaseLayout>

<!-- HERO -->

<section class="hero">
  <div class="hero-content">
    <h1>Level 4 Rooftop Restaurant</h1>
    <p>Dining Above The City</p>


	<div class="rating-badge">

<span class="stars">★★★★★</span>

<span class="rating-text">
4.8 Rating on Google
</span>

</div>

    <div class="hero-buttons">
      <a href="/menu" class="btn-primary">View Menu</a>
      <a href="/contact" class="btn-secondary">Reserve Table</a>
    </div>
  </div>
</section>


<!-- SIGNATURE DISHES -->

<section class="signature" data-aos="fade-up">

<h2>Signature Dishes</h2>

<div class="dish-grid">

{menu.categories[0].items.slice(0,3).map((item)=>(
<div class="dish-card" data-aos="zoom-in">

<img src={item.image} />

<h3>{item.name}</h3>

<p>₹{item.price}</p>

</div>
))}

</div>

</section>


<!-- EXPERIENCE -->

<section class="experience">

<h2>The Rooftop Experience</h2>

<p>
Enjoy open-air dining with city views, great ambience,
and freshly prepared Indian and Chinese cuisine.
Perfect for family dinners, celebrations and evening outings.
</p>

</section>

<!-- AMBIENCE SECTION -->

<section class="ambience" data-aos="fade-up">

<div class="ambience-overlay">

<h2>Experience Rooftop Dining Under the Stars</h2>

<p>
Relax with panoramic city views, evening breeze,
and a vibrant dining atmosphere at Level 4.
</p>

<a href="/contact" class="btn-primary">
Reserve Your Table
</a>

</div>

</section>

<!-- GALLERY PREVIEW -->

<section class="gallery-preview">

<h2>Gallery</h2>

<div class="gallery-grid">

{gallery.slice(0,4).map((img)=>(
<img src={img} />
))}

</div>

<a href="/gallery" class="btn-primary view-gallery">
View Full Gallery
</a>

</section>


<!-- EVENTS -->

<section class="events">

<h2>Events & Celebrations</h2>

<div class="event-grid">

<div class="event-card">
<h3>Birthday Parties</h3>
<p>Celebrate with rooftop ambience and great food.</p>
</div>

<div class="event-card">
<h3>Corporate Dinners</h3>
<p>Perfect place for team gatherings.</p>
</div>

<div class="event-card">
<h3>Family Celebrations</h3>
<p>Enjoy memorable evenings with loved ones.</p>
</div>

</div>

</section>

<!-- REVIEWS -->

<section class="reviews">

<h2>What Our Guests Say</h2>

<div class="review-grid">

<div class="review-card">
<p>
Amazing rooftop ambience and great food. Perfect place for dinner with friends.
</p>
<h4>★★★★★</h4>
<span>— Rahul S.</span>
</div>

<div class="review-card">
<p>
Loved the view and the service. Paneer tikka was excellent.
</p>
<h4>★★★★★</h4>
<span>— Priya M.</span>
</div>

<div class="review-card">
<p>
One of the best rooftop restaurants in Gaya. Great atmosphere.
</p>
<h4>★★★★★</h4>
<span>— Amit K.</span>
</div>

</div>

<a 
href="https://g.page/r/XXXX/review"
target="_blank"
class="btn-primary"
>
Read More Reviews on Google
</a>

</section>


<!-- INSTAGRAM -->

<section class="instagram">

<h2>Follow Us on Instagram</h2>

<div class="insta-grid">

<a href="https://www.instagram.com/level4_rooftoprestaurant/" target="_blank">
<img src="/images/insta1.jpg">
</a>

<a href="https://www.instagram.com/level4_rooftoprestaurant/" target="_blank">
<img src="/images/insta2.jpg">
</a>

<a href="https://www.instagram.com/level4_rooftoprestaurant/" target="_blank">
<img src="/images/insta3.jpg">
</a>

<a href="https://www.instagram.com/level4_rooftoprestaurant/" target="_blank">
<img src="/images/insta4.jpg">
</a>

</div>

<a
href="https://www.instagram.com/level4_rooftoprestaurant/"
target="_blank"
class="btn-primary follow-btn"
>
View More on Instagram
</a>

</section>

<!-- GOOGLE MAP -->

<section class="map">

<h2>Visit Us</h2>

<iframe
src="<iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3622.2126856100044!2d84.99984359999999!3d24.788169699999997!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x39f32b5ae9fea04f%3A0x15263546ece50d64!2sLEVEL%204%20ROOFTOP%20RESTAURANT!5e0!3m2!1sen!2sin!4v1774160118249!5m2!1sen!2sin" width="800" height="600" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>"
width="100%"
height="350"
style="border:0;">
</iframe>

</section>

</BaseLayout>