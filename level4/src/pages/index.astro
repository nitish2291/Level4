---
import BaseLayout from "../layouts/BaseLayout.astro";
import menu from "../content/menu.json";
import gallery from "../content/gallery.json";
---

<BaseLayout>

<!-- HERO -->

<section class="hero">
  <div class="hero-content">

    <h1>Level 4 Rooftop Restaurant</h1>
    <p>Dining Above The City</p>

    <div class="rating-badge">
      <span class="stars">★★★★★</span>
      <span class="rating-text">4.8 Rating on Google</span>
    </div>

    <div class="hero-buttons">
      <a href="/menu" class="btn-primary">View Menu</a>

      <a
        href="https://wa.me/919876543210?text=Hi%2C%20I%20would%20like%20to%20reserve%20a%20table%20at%20Level%204%20Rooftop%20Restaurant"
        target="_blank"
        class="btn-secondary"
      >
        Reserve Table
      </a>

    </div>

  </div>
</section>


<!-- SIGNATURE DISHES -->

<section class="signature" data-aos="fade-up">

<h2>Signature Dishes</h2>

<div class="dish-grid">

{menu.categories[0].items.slice(0,3).map((item) => (

<div class="dish-card" data-aos="zoom-in">

<img
src={item.image}
alt={item.name}
loading="lazy"
/>

<h3>{item.name}</h3>

<p>₹{item.price}</p>

</div>

))}

</div>

</section>


<!-- EXPERIENCE -->

<section class="experience">

<h2>The Rooftop Experience</h2>

<p>
Enjoy open-air dining with city views, great ambience,
and freshly prepared Indian and Chinese cuisine.
Perfect for family dinners, celebrations and evening outings.
</p>

</section>


<!-- AMBIENCE -->

<section class="ambience" data-aos="fade-up">

<div class="ambience-overlay">

<h2>Experience Rooftop Dining Under the Stars</h2>

<p>
Relax with panoramic city views, evening breeze,
and a vibrant dining atmosphere at Level 4.
</p>

<a
href="https://wa.me/919876543210?text=Hi%2C%20I%20would%20like%20to%20reserve%20a%20table%20at%20Level%204%20Rooftop%20Restaurant"
target="_blank"
class="btn-primary"
>
Reserve Your Table
</a>

</div>

</section>


<!-- GALLERY PREVIEW -->

<section class="gallery">
  <h2>Gallery</h2>

  <div class="gallery-grid">
    <img src="/images/rooftop1.jpg" />
    <img src="/images/dish1.jpg" />
    <img src="/images/dish2.jpg" />
    <img src="/images/cooking.jpg" />
    <img src="/images/food1.jpg" />
    <img src="/images/dining.jpg" />
	<img src="/images/mocktails.jpg" />
    <img src="/images/party.jpg" />
	<img src="/images/kids-birthday.jpg" />

  </div>
</section>


<a href="/gallery" class="btn-primary view-gallery">
View Full Gallery
</a>

</section>


<!-- EVENTS -->

<section class="events">

<h2>Events & Celebrations</h2>

<div class="event-grid">

<div class="event-card">
<h3>Birthday Parties</h3>
<p>Celebrate with rooftop ambience and great food.</p>
</div>

<div class="event-card">
<h3>Corporate Dinners</h3>
<p>Perfect place for team gatherings.</p>
</div>

<div class="event-card">
<h3>Family Celebrations</h3>
<p>Enjoy memorable evenings with loved ones.</p>
</div>

</div>

</section>


<!-- REVIEWS -->

<section class="reviews">

<h2>What Our Guests Say</h2>

<div class="review-grid">

<div class="review-card">
<p>
Amazing rooftop ambience and great food. Perfect place for dinner with friends.
</p>
<h4>★★★★★</h4>
<span>— Rahul S.</span>
</div>

<div class="review-card">
<p>
Loved the view and the service. Paneer tikka was excellent.
</p>
<h4>★★★★★</h4>
<span>— Priya M.</span>
</div>

<div class="review-card">
<p>
One of the best rooftop restaurants in Gaya. Great atmosphere.
</p>
<h4>★★★★★</h4>
<span>— Amit K.</span>
</div>

</div>

<div class="review-actions">

<a
href="https://www.google.com/maps/place/?q=place_id:ChIJT6D-6VorszkRZA3l7EY1JhU"
target="_blank"
class="btn-secondary">
Read Reviews
</a>

<a
href="https://search.google.com/local/writereview?placeid=ChIJT6D-6VorszkRZA3l7EY1JhU"
target="_blank"
class="btn-primary">
Leave a Google Review
</a>

</div>

</section>


<!-- INSTAGRAM -->

<section class="instagram">

<h2>Our Instagram Gallery</h2>

<!-- LightWidget WIDGET -->
<script src="https://cdn.lightwidget.com/widgets/lightwidget.js"></script>

<iframe
src="//lightwidget.com/widgets/a114ab57458e586090b7e484802db369.html"
scrolling="no"
allowtransparency="true"
class="lightwidget-widget"
style="width:100%;border:0;overflow:hidden;">
</iframe>

<a
href="https://www.instagram.com/level4_rooftoprestaurant/"
target="_blank"
class="btn-primary follow-btn"
>
Follow us on Instagram
</a>

</section>


<!-- MAP -->

<section class="map">

<h2>Visit Us</h2>

<iframe
src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3622.2126856100044!2d84.99984359999999!3d24.788169699999997!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x39f32b5ae9fea04f%3A0x15263546ece50d64!2sLEVEL%204%20ROOFTOP%20RESTAURANT!5e0!3m2!1sen!2sin!4v1774160118249!5m2!1sen!2sin"
width="100%"
height="350"
style="border:0;"
allowfullscreen=""
loading="lazy"
referrerpolicy="no-referrer-when-downgrade">
</iframe>

</section>

</BaseLayout>

<div class="mobile-reserve">
<a
href="https://wa.me/919876543210?text=Hi%2C%20I%20would%20like%20to%20reserve%20a%20table%20at%20Level%204%20Rooftop%20Restaurant"
target="_blank">
Reserve Your Table on WhatsApp
</a>
</div>