
---
import BaseLayout from "../layouts/BaseLayout.astro";
import menu from "../content/menu.json";
import gallery from "../content/gallery.json";
---

<BaseLayout>

<section class="hero">
<div class="hero-content">

<h1>Level 4 Rooftop Restaurant</h1>
<p>Dining Above The City</p>

<div class="hero-buttons">

<a href="/events" class="btn-primary">Plan an Event</a>

<a href="/menu" class="btn-tertiary">
View Menu
</a>

</div>

</div>
</section>

<section class="experience" >

<h2>The Rooftop Experience</h2>

<p>
Enjoy open-air dining with city views, great ambience,
and freshly prepared Indian and Chinese cuisine.
Perfect for family dinners, celebrations and evening outings.
</p>

</section>


<section class="event-banner >

<div class="event-banner-content">

<h2>Celebrate Your Special Moments at Level 4</h2>
<p>Birthdays • Anniversaries • Corporate Dinners</p>

<a href="/events" class="btn-primary">Explore Event Packages</a>

</div>

</section>

<section class="signature">

<h2>Signature Dishes</h2>

<div class="dish-grid">

{menu.categories[0].items.slice(0,3).map((item) => (

<div class="dish-card">

<img src={item.image} alt={item.name} loading="lazy"/>

<h3>{item.name}</h3>

<p>₹{item.price}</p>

</div>

))}

</div>

</section>

<section class="gallery">

<h2>Gallery</h2>

<div class="gallery-grid">
<img src="/images/rooftop1.jpg"/>
<img src="/images/dish1.jpg"/>
<img src="/images/dish2.jpg"/>
<img src="/images/cooking.jpg"/>
<img src="/images/food1.jpg"/>
<img src="/images/dining.jpg"/>
<img src="/images/mocktails.jpg"/>
<img src="/images/party.jpg"/>
<img src="/images/kids-birthday.jpg"/>
</div>

<a href="/gallery" class="btn-primary view-gallery">View Full Gallery</a>

</section>

<section class="events">

<h2>Events & Celebrations</h2>

<div class="event-grid">

<div class="event-card">
<h3>Birthday Parties</h3>
<p>Celebrate with rooftop ambience and great food.</p>
</div>

<div class="event-card">
<h3>Corporate Dinners</h3>
<p>Perfect place for team gatherings.</p>
</div>

<div class="event-card">
<h3>Family Celebrations</h3>
<p>Enjoy memorable evenings with loved ones.</p>
</div>

</div>

</section>

<section class="reviews">

<h2>What Our Guests Say</h2>

<div class="review-grid">

<div class="review-card">
<p>Amazing rooftop ambience and great food.</p>
<h4>★★★★★</h4>
<span>— Rahul S.</span>
</div>

<div class="review-card">
<p>Loved the view and the service.</p>
<h4>★★★★★</h4>
<span>— Priya M.</span>
</div>

<div class="review-card">
<p>One of the best rooftop restaurants in Gaya.</p>
<h4>★★★★★</h4>
<span>— Amit K.</span>
</div>

</div>

</section>

<section class="why">

<h2>The Level 4 Experience</h2>

<div class="feature-card rooftop">
  <div class="overlay">
    <h3>Rooftop City Views</h3>
  </div>
</div>

<div class="feature-card celebration">
  <div class="overlay">
    <h3>Perfect for Celebrations</h3>
  </div>
</div>

<div class="feature-card cuisine">
  <div class="overlay">
    <h3>Indian & Chinese Cuisine</h3>
  </div>
</div>

<div class="feature-card family">
  <div class="overlay">
    <h3>Family Friendly Dining</h3>
  </div>
</div>

</section>

<section class="instagram">

<h2>Life at Level 4</h2>

<div class="instagram-wrapper">

<script src="https://cdn.lightwidget.com/widgets/lightwidget.js"></script>

<iframe
src="//lightwidget.com/widgets/a114ab57458e586090b7e484802db369.html"
scrolling="no"
allowtransparency="true"
class="lightwidget-widget">
</iframe>

</div>

<div class="instagram-cta">

<p>See more moments from our rooftop experience.</p>

<a
href="https://www.instagram.com/level4_rooftoprestaurant/"
target="_blank"
class="btn-primary follow-btn">
Explore & Follow Us on Instagram
</a>

</div>

</section>

<!-- MAP -->

<section class="map">

<h2>Visit Us</h2>

<iframe
src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3622.2126856100044!2d84.99984359999999!3d24.788169699999997!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x39f32b5ae9fea04f%3A0x15263546ece50d64!2sLEVEL%204%20ROOFTOP%20RESTAURANT!5e0!3m2!1sen!2sin!4v1774160118249!5m2!1sen!2sin"
width="100%"
height="350"
style="border:0;"
allowfullscreen=""
loading="lazy"
referrerpolicy="no-referrer-when-downgrade">
</iframe>

</section>


<section class="visit">

<div class="visit-actions">

<a href="tel:+917760669444" class="btn-secondary">
📞 Call Us
</a>

<a
href="https://wa.me/917760669444"
target="_blank"
class="btn-primary">
💬 Reserve on WhatsApp
</a>

</div>

</section>

<a 
href="https://wa.me/917760669444" 
target="_blank"
class="mobile-reserve"
>
Reserve Table • WhatsApp
</a>
</BaseLayout>
